# controller-new (canary) env example

# Where controller-new listens
PORT=8081

# Where your existing controller (control-plane) is
VLLM_STUDIO_CONTROL_PLANE_BASE_URL=http://localhost:8080

# Default upstream for any /v1/* not matched below
# (can be remote, e.g. https://litellm.myhost.com)
VLLM_STUDIO_V1_DEFAULT_BASE_URL=http://localhost:4100

# Route families (can be remote URLs on any IP/host/port)
VLLM_STUDIO_V1_CHAT_BASE_URL=http://localhost:4100
VLLM_STUDIO_V1_AUDIO_BASE_URL=http://localhost:5300
VLLM_STUDIO_V1_IMAGES_BASE_URL=http://localhost:5400
VLLM_STUDIO_V1_EMBEDDINGS_BASE_URL=http://localhost:5500

# Optional upstream API keys (used only when incoming Authorization is missing)
# VLLM_STUDIO_V1_DEFAULT_API_KEY=sk-...
# VLLM_STUDIO_V1_AUDIO_API_KEY=sk-...
# VLLM_STUDIO_V1_IMAGES_API_KEY=sk-...
# VLLM_STUDIO_V1_EMBEDDINGS_API_KEY=sk-...
