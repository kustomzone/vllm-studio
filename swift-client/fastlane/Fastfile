default_platform(:ios)

require "base64"
require "shellwords"
require "tempfile"

PROJECT_ROOT = File.expand_path("..", __dir__)

def project_path(*parts)
  File.join(PROJECT_ROOT, *parts)
end

def ensure_xcode_project!
  return if ENV["SKIP_XCODEGEN"] == "1"

  project_file = project_path("vllm-studio.xcodeproj", "project.pbxproj")
  project_spec = project_path("project.yml")

  needs_generation = !File.exist?(project_file)
  needs_generation ||= File.exist?(project_spec) && File.mtime(project_spec) > File.mtime(project_file)
  return unless needs_generation

  unless system("command -v xcodegen >/dev/null 2>&1")
    UI.user_error!("xcodegen is required. Install with: brew install xcodegen")
  end

  sh("cd #{Shellwords.escape(PROJECT_ROOT)} && xcodegen generate")
end

def app_store_api_key!
  key_id = ENV["APP_STORE_CONNECT_KEY_ID"].to_s
  issuer_id = ENV["APP_STORE_CONNECT_ISSUER_ID"].to_s

  UI.user_error!("Set APP_STORE_CONNECT_KEY_ID") if key_id.empty?
  UI.user_error!("Set APP_STORE_CONNECT_ISSUER_ID") if issuer_id.empty?

  encoded_p8 = ENV["APP_STORE_CONNECT_KEY_CONTENT_BASE64"].to_s
  unless encoded_p8.empty?
    decoded_p8 = Base64.strict_decode64(encoded_p8)
    Tempfile.create(["app-store-connect", ".p8"]) do |temporaryKeyFile|
      temporaryKeyFile.write(decoded_p8)
      temporaryKeyFile.flush
      return app_store_connect_api_key(
        key_id: key_id,
        issuer_id: issuer_id,
        key_filepath: temporaryKeyFile.path,
        duration: 1200,
        in_house: false
      )
    end
  end

  key_filepath = ENV["APP_STORE_CONNECT_KEY_FILEPATH"].to_s
  if key_filepath.empty?
    key_filepath = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_#{key_id}.p8")
  end

  UI.user_error!("App Store Connect key file not found: #{key_filepath}") unless File.exist?(key_filepath)

  app_store_connect_api_key(
    key_id: key_id,
    issuer_id: issuer_id,
    key_filepath: key_filepath,
    duration: 1200,
    in_house: false
  )
end

def resolve_app_identifier(options)
  options[:app_identifier] || CredentialsManager::AppfileConfig.try_fetch_value(:app_identifier) || "com.sero.vllmstudio"
end

platform :ios do
  desc "Build and upload iOS app to TestFlight"
  lane :beta do |options|
    ensure_xcode_project!

    api_key = app_store_api_key!
    app_id = resolve_app_identifier(options)

    latest_build = 0
    begin
      latest_build = latest_testflight_build_number(
        api_key: api_key,
        app_identifier: app_id,
        initial_build_number: 0
      ).to_i
    rescue => e
      UI.important("Could not read latest TestFlight build number (#{e.message}). Starting from 0.")
    end

    next_build = latest_build + 1
    increment_build_number(
      xcodeproj: project_path("vllm-studio.xcodeproj"),
      build_number: next_build.to_s
    )

    gym(
      project: project_path("vllm-studio.xcodeproj"),
      scheme: "vllm-studio",
      configuration: "Release",
      clean: true,
      export_method: "app-store",
      output_directory: project_path("test-output", "fastlane"),
      output_name: "vllm-studio.ipa"
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
      changelog: options[:changelog]
    )
  end
end
