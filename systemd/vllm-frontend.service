[Unit]
Description=vLLM Studio Web UI (Next.js)
After=network.target vllm-studio.service

[Service]
Type=simple
User=ser
WorkingDirectory=/home/ser/lmvllm/frontend
Environment="NEXT_PUBLIC_API_URL=http://localhost:8080"
Environment="PORT=3000"
ExecStart=/usr/bin/npm start
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target

